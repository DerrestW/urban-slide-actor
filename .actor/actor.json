{
  "actorSpecification": 1,
  "name": "urban-slide-city-contact-scraper",
  "title": "Urban Slide City Official Contact Scraper",
  "description": "Finds city officials for Urban Slide outreach.",
  "version": "1.0",
  "dockerfile": "./Dockerfile",
  "input": {
    "title": "Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
      "cities": {
        "title": "Cities",
        "type": "array",
        "editor": "json",
        "default": []
      },
      "minimumContactsPerCity": {
        "title": "Min Contacts",
        "type": "integer",
        "default": 3
      },
      "maximumContactsPerCity": {
        "title": "Max Contacts",
        "type": "integer",
        "default": 8
      },
      "crawlDepth": {
        "title": "Crawl Depth",
        "type": "integer",
        "default": 3
      },
      "maximumPagesPerDomain": {
        "title": "Max Pages",
        "type": "integer",
        "default": 75
      },
      "includePdfs": {
        "title": "Include PDFs",
        "type": "boolean",
        "default": true
      }
    },
    "required": [
      "cities"
    ]
  }
}